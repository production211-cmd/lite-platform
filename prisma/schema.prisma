generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  RETAILER_LT
  VENDOR_USER
  VENDOR        // Portal-only vendor (stripped layout, no sidebar)
}

enum PortalType {
  FULL          // Full sidebar, vendor dashboard (e.g. Urban Threads)
  PORTAL        // Stripped layout, portal-only (e.g. Link2Lux, Eleonora Bonucci)
}

enum EconomicModel {
  MARKETPLACE
  WHOLESALE
}

enum VendorLocation {
  DOMESTIC_US
  INTERNATIONAL
}

enum IntegrationType {
  SHOPIFY
  API
  MAGENTO
  CSV
}

enum BrandStructure {
  UNI_BRAND
  MULTI_BRAND
}

enum ShippingModel {
  DTC_A
  DTC_B
  B2B_A
  B2B_B
}

enum Currency {
  USD
  EUR
  GBP
  CHF
  SEK
  DKK
  NOK
  CAD
  AUD
}

enum ProductStatus {
  PENDING_REVIEW
  APPROVED
  QUALIFIED
  NEEDS_REVIEW
  PUSHED
  REJECTED
  ARCHIVED
  DELETED_BY_VENDOR
}

// 8-stage pipeline aligned to God File
enum OrderStatus {
  PLACED
  SPLIT
  VENDOR_ACCEPT
  FRAUD_HOLD
  VENDOR_REJECTED
  GENERATE_LABEL
  SHIPPED
  IN_TRANSIT
  DELIVERED
  SETTLED
  CANCELLED
  RETURN_INITIATED
  RETURN_RECEIVED
  RETURN_COMPLETED
}

enum ShipmentLeg {
  LEG_1
  LEG_2
  DIRECT
}

enum ShipmentStatus {
  LABEL_CREATED
  LABEL_VOIDED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  EXCEPTION
  RETURNED
}

enum ReturnStatus {
  INITIATED
  LABEL_GENERATED
  IN_TRANSIT
  RECEIVED_WAREHOUSE
  INSPECTING
  APPROVED
  REJECTED
  REFUNDED
  FORWARDED_TO_VENDOR
  COMPLETED
}

enum PayoutCycle {
  NEXT_DAY
  NET_14
  NET_30
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  ON_HOLD
}

enum SettlementStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  PARTIALLY_PAID
  DISPUTED
  CANCELLED
}

enum IdempotencyStatus {
  PROCESSING
  COMPLETED
  FAILED
}

enum MessageDepartment {
  OPS
  RMS
  CX
  CATALOG_BUYER
  VENDOR_SUPPORT
}

enum MessagePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum MessageStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum DeductionType {
  SHIPPING_COST
  PENALTY
  RETURN_REFUND
  MARKETPLACE_FEE
  OTHER
}

enum PricingStrategy {
  PREMIUM_POSITIONING
  COMPETITIVE_PRICING
  DYNAMIC_PRICING
  CLEARANCE_PRICING
  EVENT_PRICING
}

enum ComplianceRisk {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Carrier {
  FEDEX
  DHL
  UPS
}

enum OnboardingStepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  role          UserRole
  vendorId      String?
  vendor        Vendor?   @relation(fields: [vendorId], references: [id])
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sentMessages     Message[]        @relation("SentMessages")
  assignedMessages MessageThread[]  @relation("AssignedAgent")
  refreshTokens    RefreshToken[]
  vendorAccess     VendorAccess?
  notifications    Notification[]

  @@index([email])
  @@index([vendorId])
}

// ============================================================
// REFRESH TOKENS — Family-based with reuse detection
// ============================================================

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyId  String
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
}

// ============================================================
// VENDOR ACCESS — Maps user to vendor with portal type
// Addresses Perplexity Mistake 2C
// ============================================================

model VendorAccess {
  id              String      @id @default(cuid())
  userId          String      @unique
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendorId        String
  vendor          Vendor      @relation(fields: [vendorId], references: [id])
  portalType      PortalType  @default(FULL)
  shipFromAddress Json?       // { street, city, state, zip, country }
  permissions     Json?       // Granular permission overrides
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([vendorId])
}

// ============================================================
// VENDORS
// ============================================================

model Vendor {
  id                String          @id @default(cuid())
  name              String
  slug              String          @unique
  economicModel     EconomicModel
  location          VendorLocation
  country           String          @default("US")
  city              String?
  integrationType   IntegrationType
  brandStructure    BrandStructure
  currency          Currency        @default(USD)
  shippingModel     ShippingModel
  commissionRate    Float?
  payoutCycle       PayoutCycle     @default(NET_30)
  contactEmail      String?
  contactPhone      String?
  taxId             String?
  bankingDetails    Json?
  logoUrl           String?
  isActive          Boolean         @default(true)
  onboardedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  connectorConfig      VendorConnectorConfig?
  users                User[]
  vendorAccess         VendorAccess[]
  products             Product[]
  vendorOrders         VendorOrder[]
  shipments            Shipment[]
  returns              Return[]
  payouts              Payout[]
  settlements          Settlement[]
  deductions           Deduction[]
  messageThreads       MessageThread[]
  performanceMetrics   VendorPerformance[]
  onboardingSteps      VendorOnboardingStep[]
  shopifyProductMaps   ShopifyProductMap[]

  @@index([slug])
  @@index([economicModel])
  @@index([location])
}

model VendorConnectorConfig {
  id                 String          @id @default(cuid())
  vendorId           String          @unique
  vendor             Vendor          @relation(fields: [vendorId], references: [id])
  integrationType    IntegrationType
  shopifyStoreUrl    String?
  shopifyAccessToken String?
  apiEndpoint        String?
  apiKey             String?
  apiSecret          String?
  webhookSecret      String?
  syncEnabled        Boolean         @default(true)
  lastSyncAt         DateTime?
  syncFrequency      Int?            @default(300)
  config             Json?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model VendorPerformance {
  id                  String   @id @default(cuid())
  vendorId            String
  vendor              Vendor   @relation(fields: [vendorId], references: [id])
  period              String
  fulfillmentRate     Float?
  acceptanceRate      Float?
  slaComplianceRate   Float?
  returnRate          Float?
  avgShipTime         Float?
  totalOrders         Int      @default(0)
  totalRevenue        Float    @default(0)
  totalCommission     Float    @default(0)
  createdAt           DateTime @default(now())

  @@unique([vendorId, period])
  @@index([vendorId])
}

// ============================================================
// VENDOR ONBOARDING — Step-by-step tracking
// ============================================================

model VendorOnboardingStep {
  id          String                @id @default(cuid())
  vendorId    String
  vendor      Vendor                @relation(fields: [vendorId], references: [id])
  stepName    String                // e.g. "contract_signed", "bank_details", "catalog_uploaded"
  status      OnboardingStepStatus  @default(PENDING)
  completedAt DateTime?
  notes       String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([vendorId, stepName])
  @@index([vendorId])
}

// ============================================================
// SHOPIFY PRODUCT MAP — External ID mapping
// ============================================================

model ShopifyProductMap {
  id                String    @id @default(cuid())
  vendorId          String
  vendor            Vendor    @relation(fields: [vendorId], references: [id])
  productId         String
  product           Product   @relation(fields: [productId], references: [id])
  shopifyProductId  String
  shopifyVariantId  String?
  shopifyStoreUrl   String?
  lastSyncAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([shopifyProductId])
  @@index([vendorId])
  @@index([productId])
}

// ============================================================
// PRODUCTS & CATALOG
// ============================================================

model Product {
  id                  String        @id @default(cuid())
  vendorId            String
  vendor              Vendor        @relation(fields: [vendorId], references: [id])
  shopifyProductId    String?
  vendorSku           String?
  retailerSku         String?
  title               String
  description         String?
  bodyHtml            String?
  productType         String?
  category            String?
  subcategory         String?
  brand               String?
  tags                String[]
  status              ProductStatus @default(PENDING_REVIEW)

  compareAtPrice      Float?
  salesPrice          Float?
  retailerCost        Float?
  vendorCost          Float?
  currency            Currency      @default(USD)

  enrichmentScore     Int?          @default(0)
  attributeScore      Int?          @default(0)
  descriptionScore    Int?          @default(0)
  seoScore            Int?          @default(0)
  geoScore            Int?          @default(0)
  metaTitle           String?
  metaDescription     String?
  keywords            String[]

  hsCode              String?
  countryOfOrigin     String?
  complianceRisk      ComplianceRisk?
  requiresFda         Boolean       @default(false)
  requiresCites       Boolean       @default(false)

  shipsFrom           String?

  images              ProductImage[]
  variants            ProductVariant[]
  priceHistory        ProductPriceHistory[]
  orderItems          OrderItem[]
  shopifyMaps         ShopifyProductMap[]

  isDeleted           Boolean       @default(false)
  deletedByVendorAt   DateTime?
  publishedAt         DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([vendorId])
  @@index([status])
  @@index([shopifyProductId])
  @@index([brand])
  @@index([category])
}

model ProductVariant {
  id                  String    @id @default(cuid())
  productId           String
  product             Product   @relation(fields: [productId], references: [id])
  shopifyVariantId    String?
  vendorSku           String?
  retailerSku         String?
  title               String?
  size                String?
  color               String?
  material            String?
  weight              Float?
  weightUnit          String?   @default("kg")
  compareAtPrice      Float?
  salesPrice          Float?
  retailerCost        Float?
  vendorCost          Float?
  inventoryQuantity   Int       @default(0)
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  orderItems          OrderItem[]

  @@index([productId])
  @@index([shopifyVariantId])
}

model ProductImage {
  id            String    @id @default(cuid())
  productId     String
  product       Product   @relation(fields: [productId], references: [id])
  url           String
  altText       String?
  position      Int       @default(0)
  isGenerated   Boolean   @default(false)
  pipeline      String?
  isCompliant   Boolean   @default(true)
  complianceIssues String[]
  createdAt     DateTime  @default(now())

  @@index([productId])
}

model ProductPriceHistory {
  id            String    @id @default(cuid())
  productId     String
  product       Product   @relation(fields: [productId], references: [id])
  field         String
  oldValue      Float?
  newValue      Float?
  currency      Currency
  source        String
  changedBy     String?
  createdAt     DateTime  @default(now())

  @@index([productId])
  @@index([createdAt])
}

// ============================================================
// ORDERS — Renamed: Order → MarketplaceOrder, SubOrder → VendorOrder
// Using @@map to keep DB table names stable for data continuity
// ============================================================

model MarketplaceOrder {
  id                  String      @id @default(cuid())
  shopifyOrderId      String?     @unique
  orderNumber         String      @unique
  customerEmail       String?
  customerName        String?
  shippingAddress     Json?
  billingAddress      Json?
  totalAmount         Float
  currency            Currency    @default(USD)
  status              OrderStatus @default(PLACED)
  fraudStatus         String?
  fraudProvider       String?
  paymentStatus       String?
  notes               String?
  placedAt            DateTime    @default(now())
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  vendorOrders        VendorOrder[]
  priceSnapshot       OrderPriceSnapshot?

  @@index([shopifyOrderId])
  @@index([orderNumber])
  @@index([status])
  @@index([placedAt])
  @@map("Order")
}

model VendorOrder {
  id                  String      @id @default(cuid())
  orderId             String
  order               MarketplaceOrder @relation(fields: [orderId], references: [id])
  vendorId            String
  vendor              Vendor      @relation(fields: [vendorId], references: [id])
  vendorOrderId       String?
  status              OrderStatus @default(PLACED)
  subtotal            Float
  commission          Float?
  commissionRate      Float?
  vendorEarnings      Float?
  currency            Currency    @default(USD)
  acceptedAt          DateTime?
  rejectedAt          DateTime?
  rejectionReason     String?
  shippedAt           DateTime?
  deliveredAt         DateTime?
  slaDeadline         DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  items               OrderItem[]
  shipments           Shipment[]
  returns             Return[]
  settlements         Settlement[]

  @@index([orderId])
  @@index([vendorId])
  @@index([status])
  @@map("SubOrder")
}

model OrderItem {
  id                  String         @id @default(cuid())
  vendorOrderId       String
  vendorOrder         VendorOrder    @relation(fields: [vendorOrderId], references: [id])
  productId           String
  product             Product        @relation(fields: [productId], references: [id])
  variantId           String?
  variant             ProductVariant? @relation(fields: [variantId], references: [id])
  quantity            Int
  unitPrice           Float
  totalPrice          Float
  retailerCost        Float?
  vendorCost          Float?
  currency            Currency      @default(USD)
  createdAt           DateTime      @default(now())

  @@index([vendorOrderId])
  @@index([productId])
  @@map("OrderItem")
}

model OrderPriceSnapshot {
  id                  String           @id @default(cuid())
  orderId             String           @unique
  order               MarketplaceOrder @relation(fields: [orderId], references: [id])
  snapshot            Json
  exchangeRate        Float?
  exchangeRateSource  String?
  exchangeRateAt      DateTime?
  createdAt           DateTime         @default(now())
}

// ============================================================
// SHIPPING
// ============================================================

model Shipment {
  id                  String          @id @default(cuid())
  vendorOrderId       String
  vendorOrder         VendorOrder     @relation(fields: [vendorOrderId], references: [id])
  vendorId            String
  vendor              Vendor          @relation(fields: [vendorId], references: [id])
  shippingModel       ShippingModel
  carrier             Carrier?
  leg                 ShipmentLeg     @default(DIRECT)
  status              ShipmentStatus  @default(LABEL_CREATED)

  trackingNumber      String?
  labelUrl            String?
  labelVoidedAt       DateTime?
  packingSlipUrl      String?

  commercialInvoiceUrl String?
  etdUploaded         Boolean         @default(false)
  etdUploadedAt       DateTime?

  carrierAccountNumber String?
  serviceType         String?
  estimatedDelivery   DateTime?
  actualDelivery      DateTime?

  weight              Float?
  weightUnit          String?         @default("kg")
  length              Float?
  width               Float?
  height              Float?
  dimensionUnit       String?         @default("cm")

  shippingCost        Float?
  costCurrency        Currency        @default(USD)
  fuelSurcharge       Float?
  dutiesAndTaxes      Float?

  originAddress       Json?
  destinationAddress  Json?

  parentShipmentId    String?
  parentShipment      Shipment?       @relation("ShipmentLegs", fields: [parentShipmentId], references: [id])
  childShipments      Shipment[]      @relation("ShipmentLegs")

  trackingEvents      TrackingEvent[]

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([vendorOrderId])
  @@index([vendorId])
  @@index([trackingNumber])
  @@index([status])
}

model TrackingEvent {
  id            String    @id @default(cuid())
  shipmentId    String
  shipment      Shipment  @relation(fields: [shipmentId], references: [id])
  status        String
  description   String?
  location      String?
  timestamp     DateTime
  rawPayload    Json?
  createdAt     DateTime  @default(now())

  @@index([shipmentId])
  @@index([timestamp])
}

// ============================================================
// RETURNS
// ============================================================

model Return {
  id                   String        @id @default(cuid())
  vendorOrderId        String
  vendorOrder          VendorOrder   @relation(fields: [vendorOrderId], references: [id])
  vendorId             String
  vendor               Vendor        @relation(fields: [vendorId], references: [id])
  status               ReturnStatus  @default(INITIATED)
  reason               String?
  customerNotes        String?
  returnTrackingNumber String?
  returnLabelUrl       String?
  inspectionNotes      String?
  inspectionPhotos     String[]
  isRgrEligible        Boolean       @default(false)
  rgrDeclarationRef    String?
  refundAmount         Float?
  refundCurrency       Currency      @default(USD)
  initiatedAt          DateTime      @default(now())
  receivedAt           DateTime?
  inspectedAt          DateTime?
  completedAt          DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([vendorOrderId])
  @@index([vendorId])
  @@index([status])
}

// ============================================================
// FINANCE & PAYOUTS
// ============================================================

model Payout {
  id                  String        @id @default(cuid())
  vendorId            String
  vendor              Vendor        @relation(fields: [vendorId], references: [id])
  amount              Float
  currency            Currency
  exchangeRate        Float?
  exchangeRateAt      DateTime?
  status              PayoutStatus  @default(PENDING)
  payoutCycle         PayoutCycle
  processorRef        String?
  processedAt         DateTime?
  failedAt            DateTime?
  failureReason       String?
  notes               String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  items               PayoutItem[]

  @@index([vendorId])
  @@index([status])
}

model PayoutItem {
  id              String    @id @default(cuid())
  payoutId        String
  payout          Payout    @relation(fields: [payoutId], references: [id])
  vendorOrderId   String?
  description     String?
  amount          Float
  currency        Currency
  createdAt       DateTime  @default(now())

  @@index([payoutId])
}

// ============================================================
// SETTLEMENT — Async-safe with Revolut state tracking
// Addresses Perplexity Mistake 2A
// ============================================================

model Settlement {
  id                  String            @id @default(cuid())
  vendorId            String
  vendor              Vendor            @relation(fields: [vendorId], references: [id])
  vendorOrderId       String?
  vendorOrder         VendorOrder?      @relation(fields: [vendorOrderId], references: [id])
  amount              Float
  currency            Currency
  exchangeRate        Float?
  status              SettlementStatus  @default(PENDING)
  processorRef        String?           // Revolut transaction ID
  processorResponse   Json?             // Full Revolut API response
  retryCount          Int               @default(0)
  maxRetries          Int               @default(3)
  lastAttemptAt       DateTime?
  completedAt         DateTime?
  failedAt            DateTime?
  failureReason       String?
  notes               String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  events              SettlementEvent[]

  @@index([vendorId])
  @@index([vendorOrderId])
  @@index([status])
}

// ============================================================
// IDEMPOTENCY KEYS — Prevents duplicate payment/API calls
// Addresses Perplexity Mistake 2A
// ============================================================

model IdempotencyKey {
  id              String            @id @default(cuid())
  key             String            @unique  // Unique key per operation
  scope           String            // e.g. "settlement", "payout", "label_generation"
  status          IdempotencyStatus @default(PROCESSING)
  requestHash     String?           // Hash of the request payload
  responseData    Json?             // Cached response for replay
  completedAt     DateTime?
  expiresAt       DateTime          // Auto-cleanup after expiry
  createdAt       DateTime          @default(now())

  @@index([scope])
  @@index([expiresAt])
}

model Deduction {
  id            String          @id @default(cuid())
  vendorId      String
  vendor        Vendor          @relation(fields: [vendorId], references: [id])
  type          DeductionType
  amount        Float
  currency      Currency        @default(USD)
  reason        String?
  referenceId   String?
  isApplied     Boolean         @default(false)
  appliedAt     DateTime?
  createdAt     DateTime        @default(now())

  @@index([vendorId])
  @@index([type])
}

// ============================================================
// MESSAGING
// ============================================================

model MessageThread {
  id                  String            @id @default(cuid())
  vendorId            String
  vendor              Vendor            @relation(fields: [vendorId], references: [id])
  subject             String
  department          MessageDepartment
  priority            MessagePriority   @default(NORMAL)
  status              MessageStatus     @default(OPEN)
  assignedToId        String?
  assignedTo          User?             @relation("AssignedAgent", fields: [assignedToId], references: [id])
  referenceType       String?
  referenceId         String?
  slaDeadline         DateTime?
  resolvedAt          DateTime?
  closedAt            DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  messages            Message[]

  @@index([vendorId])
  @@index([department])
  @@index([status])
  @@index([assignedToId])
}

model Message {
  id            String        @id @default(cuid())
  threadId      String
  thread        MessageThread @relation(fields: [threadId], references: [id])
  senderId      String
  sender        User          @relation("SentMessages", fields: [senderId], references: [id])
  content       String
  isInternal    Boolean       @default(false)
  attachments   String[]
  readAt        DateTime?
  createdAt     DateTime      @default(now())

  @@index([threadId])
  @@index([senderId])
}

// ============================================================
// COMPLIANCE
// ============================================================

model ComplianceDocument {
  id                  String    @id @default(cuid())
  shipmentId          String?
  productId           String?
  vendorId            String?
  documentType        String
  fileUrl             String
  generatedAt         DateTime  @default(now())
  uploadedToCarrier   Boolean   @default(false)
  uploadedAt          DateTime?
  createdAt           DateTime  @default(now())

  @@index([shipmentId])
  @@index([productId])
}

// ============================================================
// TYPED LOG TABLES — Replaces generic EventLog
// Addresses Perplexity Mistake 2B
// ============================================================

// 1. Shopify Webhook Log — with externalId for deduplication
model ShopifyWebhookLog {
  id            String    @id @default(cuid())
  vendorId      String?
  externalId    String?   @unique  // Shopify webhook X-Shopify-Webhook-Id for dedup
  topic         String    // products/create, orders/create, etc.
  shopDomain    String?
  rawPayload    Json?
  parsedData    Json?
  status        String    @default("success") // success, error, skipped, duplicate
  errorMessage  String?
  processingMs  Int?      // Processing duration in milliseconds
  createdAt     DateTime  @default(now())

  @@index([vendorId])
  @@index([topic])
  @@index([externalId])
  @@index([createdAt])
}

// 2. Label Generation Log — with tracking details
model LabelGenerationLog {
  id                String    @id @default(cuid())
  shipmentId        String?
  vendorOrderId     String?
  trackingNumber    String?
  carrier           Carrier?
  carrierAccount    String?
  action            String    // generated, voided, regenerated
  labelUrl          String?
  labelGcsPath      String?   // Cloud storage path for label PDF
  serviceType       String?
  shippingCost      Float?
  reason            String?
  performedBy       String?   // userId
  createdAt         DateTime  @default(now())

  @@index([shipmentId])
  @@index([vendorOrderId])
  @@index([trackingNumber])
  @@index([createdAt])
}

// 3. Settlement Event — State transitions for payout lifecycle
model SettlementEvent {
  id              String    @id @default(cuid())
  settlementId    String
  settlement      Settlement @relation(fields: [settlementId], references: [id])
  fromStatus      String?
  toStatus        String
  trigger         String    // manual, scheduled, webhook, retry
  processorRef    String?   // External payment processor reference
  amount          Float?
  errorMessage    String?
  metadata        Json?
  createdAt       DateTime  @default(now())

  @@index([settlementId])
  @@index([createdAt])
}

// 4. Sync Cursor Log — Tracking sync state for each integration
model SyncCursorLog {
  id              String    @id @default(cuid())
  vendorId        String
  integrationType IntegrationType
  cursorType      String    // products, orders, inventory, prices
  lastCursorValue String?   // Last processed ID or timestamp
  lastSyncAt      DateTime?
  itemsSynced     Int       @default(0)
  status          String    @default("success") // success, error, partial
  errorMessage    String?
  createdAt       DateTime  @default(now())

  @@unique([vendorId, integrationType, cursorType])
  @@index([vendorId])
  @@index([createdAt])
}

// ─── Notifications ───────────────────────────────────────────────
enum NotificationType {
  ORDER
  SHIPMENT
  RETURN
  VENDOR
  PRODUCT
  FINANCE
  SYSTEM
  ALERT
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Notification {
  id          String               @id @default(cuid())
  userId      String
  type        NotificationType
  priority    NotificationPriority @default(MEDIUM)
  title       String
  message     String
  isRead      Boolean              @default(false)
  actionUrl   String?
  actionLabel String?
  metadata    Json?
  createdAt   DateTime             @default(now())

  user        User                 @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([createdAt])
}

// ─── Platform Settings ───────────────────────────────────────────
model PlatformSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  category    String   @default("general")
  label       String?
  description String?
  updatedBy   String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([category])
}
